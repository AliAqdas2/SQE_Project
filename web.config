<?xml version="1.0" encoding="utf-8"?>
<!--
  Plegit 2.0 - IIS Configuration
  ================================
  This web.config is for hosting the Node.js application in IIS using iisnode.
  
  Prerequisites:
  1. Install Node.js on the server
  2. Install iisnode module: https://github.com/azure/iisnode/wiki/iisnode-releases
  3. Install URL Rewrite Module: https://www.iis.net/downloads/microsoft/url-rewrite
  4. Run 'npm run build' before deploying
  
  Entry Point: dist/index.js (compiled from TypeScript)
-->
<configuration>
  
  <!-- Application Settings (Environment Variables) -->
  <appSettings>
    <!-- Override these in production or use Windows Environment Variables -->
    <add key="NODE_ENV" value="production" />
    <!-- Database connection - SET THIS IN WINDOWS ENVIRONMENT VARIABLES FOR SECURITY -->
    <!-- <add key="DATABASE_URL" value="postgresql://user:pass@host:5432/dbname" /> -->
    <!-- Session secret - SET THIS IN WINDOWS ENVIRONMENT VARIABLES FOR SECURITY -->
    <!-- <add key="SESSION_SECRET" value="your-production-secret" /> -->
  </appSettings>
  
  <system.webServer>
    
    <!-- Handler: Route requests to iisnode for the compiled entry point -->
    <handlers>
      <add name="iisnode" path="dist/index.js" verb="*" modules="iisnode" />
    </handlers>
    
    <!-- URL Rewrite Rules -->
    <rewrite>
      <rules>
        
        <!-- Rule 1: Don't interfere with node-inspector debugger -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist/index.js\/debug[\/]?" />
        </rule>
        
        <!-- Rule 2: Don't interfere with iisnode logs -->
        <rule name="LogFile" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^iisnode" />
        </rule>
        
        <!-- Rule 3: Serve static assets from dist/public directly -->
        <rule name="StaticAssets" stopProcessing="true">
          <match url="^assets/(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="dist/public/assets/{R:1}" />
        </rule>
        
        <!-- Rule 4: Serve other static files from dist/public -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url="(.*\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map|json))$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="dist/public/{R:0}" />
        </rule>
        
        <!-- Rule 5: All other requests go to Node.js application -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="dist/index.js" />
        </rule>
        
      </rules>
    </rewrite>
    
    <!-- Security: Hide sensitive directories from public access -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".env" />
          <add segment=".git" />
          <add segment="server" />
          <add segment="client" />
          <add segment="shared" />
          <add segment="migrations" />
          <add segment="scripts" />
        </hiddenSegments>
        <!-- Allow large file uploads (50MB for media/documents) -->
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
    
    <!-- HTTP Errors: Custom error pages -->
    <httpErrors existingResponse="PassThrough" />
    
    <!-- MIME Types: Add modern file types -->
    <staticContent>
      <remove fileExtension=".woff" />
      <remove fileExtension=".woff2" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>
    
    <!-- iisnode Configuration -->
    <iisnode
      node_env="production"
      nodeProcessCountPerApplication="0"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      maxNamedPipeConnectionPoolSize="512"
      maxNamedPipePooledConnectionAge="30000"
      asyncCompletionThreadCount="0"
      initialRequestBufferSize="4096"
      maxRequestBufferSize="65536"
      watchedFiles="web.config;iisnode.yml;dist/*.js"
      uncFileChangesPollingInterval="5000"
      gracefulShutdownTimeout="60000"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      debugHeaderEnabled="false"
      devErrorsEnabled="false"
      flushResponse="false"
      enableXFF="true"
      promoteServerVars="AUTH_USER,AUTH_TYPE,LOGON_USER,REMOTE_USER,SERVER_NAME,SERVER_PORT,HTTPS"
    />
    
    <!-- Compression for better performance -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    
    <!-- HTTP Response Headers for security -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-XSS-Protection" value="1; mode=block" />
      </customHeaders>
    </httpProtocol>
    
  </system.webServer>
  
  <!-- WebSocket Support (if needed for real-time features) -->
  <system.web>
    <httpRuntime requestValidationMode="2.0" />
  </system.web>
  
</configuration>
